{
  "name": "task-tracker-gobops",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:ios": "playwright test --project=webkit-iphone-15 --project=webkit-iphone-se --project=webkit-ipad-pro",
    "test:ios:iphone15": "playwright test --project=webkit-iphone-15",
    "test:ios:headed": "playwright test --project=webkit-iphone-15 --headed",
    "test:ios:debug": "playwright test --project=webkit-iphone-15 --debug",
    "install:webkit": "playwright install webkit"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^4.2.3",
    "@tsconfig/svelte": "^5.0.2",
    "dotenv": "^17.4.2",
    "jsdom": "^29.0.2",
    "svelte": "^4.2.8",
    "svelte-check": "^3.6.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "firebase": "^10.7.1",
    "leaflet": "^1.9.4",
    "vite-plugin-pwa": "^0.17.4"
  }
}
